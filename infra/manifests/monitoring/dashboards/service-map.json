{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "jaeger",
      "name": "Jaeger",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Service topology map for mini-obs-platform: frontend-svc -> order-svc -> inventory-svc",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "jaeger", "uid": "jaeger" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "arc__failed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "arc__passed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "nodes": {
          "mainStatUnit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": { "type": "jaeger", "uid": "jaeger" },
          "queryType": "dependencyGraph",
          "refId": "A",
          "service": ""
        }
      ],
      "title": "Service Dependency Graph",
      "description": "Shows inter-service call relationships derived from Jaeger distributed traces. Nodes = services, Edges = call paths with latency.",
      "type": "nodeGraph"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 2,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{namespace=\"observability-demo\",job=\"frontend-svc\"}[5m]))",
          "legendFormat": "frontend-svc P99",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{namespace=\"observability-demo\",job=\"order-svc\"}[5m]))",
          "legendFormat": "order-svc P99",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{namespace=\"observability-demo\",job=\"inventory-svc\"}[5m]))",
          "legendFormat": "inventory-svc P99",
          "refId": "C"
        }
      ],
      "title": "P99 Latency per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 3,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_requests_total{namespace=\"observability-demo\"}[5m])",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ],
      "title": "Request Rate per Service",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["mini-obs-platform", "service-map", "jaeger"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Service Map — mini-obs-platform",
  "uid": "mini-obs-service-map",
  "version": 1
}
